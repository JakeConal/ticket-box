# Runtime
APP_PUBLIC_URL=http://localhost:8088
NGINX_PORT=8088
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
NEXT_PUBLIC_API_BASE_URL=/api

# PostgreSQL
POSTGRES_DB=ticketbox
POSTGRES_USER=ticketbox
POSTGRES_PASSWORD=ticketbox
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ticketbox
SPRING_DATASOURCE_USERNAME=ticketbox
SPRING_DATASOURCE_PASSWORD=ticketbox
SPRING_DATASOURCE_MAX_POOL_SIZE=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s

# Auth and queue JWTs
AUTH_JWT_SECRET=replace-with-a-long-random-auth-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=7d
QUEUE_JWT_SECRET=replace-with-a-long-random-queue-secret
QUEUE_ENABLED=true
QUEUE_ACTIVE_WINDOW_BEFORE=5m
QUEUE_ACTIVE_WINDOW_AFTER=30m
QUEUE_ADMIT_BATCH_SIZE=10
QUEUE_ADMISSION_DELAY=1s
QUEUE_ADMISSION_INITIAL_DELAY=1s
QUEUE_ADMISSION_TOKEN_TTL=3m
QUEUE_TTL=2h

# QR e-ticket signing keys
QR_KEY_ID=local-dev
QR_PRIVATE_KEY_PATH=./keys/qr-private.pem
QR_PUBLIC_KEY_PATH=./keys/qr-public.pem

# VNPAY sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8088/api/payments/vnpay/callback
VNPAY_IPN_URL=http://localhost:8088/api/payments/vnpay/ipn

# MoMo sandbox
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_RETURN_URL=http://localhost:8088/api/payments/momo/callback
MOMO_IPN_URL=http://localhost:8088/api/payments/momo/callback

# AI artist bio
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT=30s
ARTIST_PDF_STORAGE_DIR=./storage/artist-pdfs
ARTIST_PDF_MAX_BYTES=20971520
ARTIST_PDF_MAX_PAGES=20
ARTIST_PDF_MAX_EXTRACTED_CHARS=40000
ARTIST_BIO_MAX_PROMPT_CHARS=20000
ARTIST_PDF_EXTRACTION_TIMEOUT=10s

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false

# VIP CSV import
VIP_IMPORT_DIR=./imports/vip
