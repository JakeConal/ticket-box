{
  "name": "ticket-box",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "web:dev": "pnpm --filter ticketbox-web dev",
    "web:build": "pnpm --filter ticketbox-web build",
    "web:start": "pnpm --filter ticketbox-web start",
    "checker:start": "npm --prefix ticketbox-checker start",
    "checker:test": "npm --prefix ticketbox-checker test",
    "checker:typecheck": "npm --prefix ticketbox-checker run typecheck"
  }
}
